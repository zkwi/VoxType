{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "VoxType",
  "version": "0.1.7",
  "identifier": "com.voxtype.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:18080",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "VoxType",
        "width": 1280,
        "height": 760,
        "minWidth": 1100,
        "minHeight": 680,
        "decorations": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "windows": {
      "webviewInstallMode": {
        "type": "embedBootstrapper"
      },
      "nsis": {
        "languages": ["SimpChinese", "TradChinese", "English"],
        "displayLanguageSelector": false,
        "installMode": "currentUser",
        "minimumWebview2Version": "120.0.0.0"
      }
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
